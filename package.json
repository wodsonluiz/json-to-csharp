{
  "name": "json-to-csharp",
  "displayName": "json-to-csharp",
  "description": "Extension convert json to csharp class",
  "version": "1.0.3",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "json-to-csharp.convert",
        "title": "Convert JSON to C# Class"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "json-to-csharp.convert",
          "when": "editorLangId == json",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "json-to-csharp.convert",
          "when": "resourceExtname == .json",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "build": "tsc -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.13",
    "@types/vscode": "^1.109.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "quicktype-core": "^23.2.6"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wodsonluiz/json-to-csharp"
  },
  "publisher": "wodson",
  "icon": "icon.png"
}
